/* pages/login/login.wxss - AI科技风格 */

/* ==================== 容器 ==================== */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #0A0E1A 0%, #1A1F2E 100%);
  display: flex;
  flex-direction: column;
}

/* ==================== 头部区域 ==================== */
.login-header {
  position: relative;
  height: 480rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(22, 93, 255, 0.15) 0%, rgba(123, 97, 255, 0.15) 100%);
  transform: skewY(-6deg);
  transform-origin: top left;
}

/* AI网格背景 */
.header-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    linear-gradient(rgba(22, 93, 255, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(22, 93, 255, 0.03) 1px, transparent 1px);
  background-size: 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  padding: 100rpx 32rpx 60rpx;
  text-align: center;
}

/* AI Logo */
.ai-logo {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  background: linear-gradient(135deg, #165DFF 0%, #7B61FF 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(22, 93, 255, 0.3);
  position: relative;
}

/* AI Logo呼吸光效 */
.ai-logo::after {
  content: '';
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #165DFF 0%, #7B61FF 100%);
  opacity: 0.2;
  animation: breathe 2s ease-in-out infinite;
  z-index: -1;
}

.logo-icon {
  font-size: 60rpx;
  color: #FFFFFF;
}

.app-name {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #E8F3FF;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.app-slogan {
  display: block;
  font-size: 28rpx;
  color: rgba(232, 243, 255, 0.7);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* ==================== 登录表单 ==================== */
.login-form {
  flex: 1;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 32rpx 32rpx 0 0;
  backdrop-filter: blur(20rpx);
  padding: 48rpx 32rpx 32rpx;
  margin-top: -32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-bottom: none;
}

.login-section {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #E8F3FF;
  margin-bottom: 12rpx;
  display: block;
  letter-spacing: 0.5rpx;
}

.section-desc {
  font-size: 26rpx;
  color: rgba(232, 243, 255, 0.6);
  margin-bottom: 32rpx;
  display: block;
  line-height: 1.6;
}

/* ==================== 登录按钮 ==================== */
.login-btn {
  width: 100%;
  height: 96rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  border: none;
  position: relative;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  margin-bottom: 16rpx;
}

.login-btn::after {
  border: none;
}

.wechat-btn {
  background: linear-gradient(135deg, #07C160 0%, #05A84E 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.25);
}

.wechat-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

/* 微信按钮流光效果 */
.wechat-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15), transparent);
  transition: 0.6s;
}

.wechat-btn:active::before {
  left: 100%;
}

.phone-btn {
  background: rgba(22, 93, 255, 0.08);
  color: #165DFF;
  border: 1rpx solid rgba(22, 93, 255, 0.2);
  backdrop-filter: blur(10rpx);
}

.phone-btn:active {
  background: rgba(22, 93, 255, 0.15);
  border-color: rgba(22, 93, 255, 0.4);
  transform: translateY(2rpx);
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
}

/* ==================== 分隔线 ==================== */
.divider {
  display: flex;
  align-items: center;
  margin: 48rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.06);
}

.divider-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: rgba(232, 243, 255, 0.4);
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

/* ==================== 错误提示 ==================== */
.error-message {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: rgba(255, 77, 79, 0.08);
  border: 1rpx solid rgba(255, 77, 79, 0.15);
  border-radius: 12rpx;
  margin-bottom: 32rpx;
}

.error-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  color: #FF4D4F;
}

.error-text {
  font-size: 26rpx;
  color: #FF4D4F;
  font-weight: 500;
}

/* ==================== 注册链接 ==================== */
.register-link {
  text-align: center;
  margin-top: 32rpx;
  font-size: 26rpx;
  color: rgba(232, 243, 255, 0.6);
}

.link-text {
  color: #165DFF;
  font-weight: 600;
  margin-left: 6rpx;
}

.link-text:active {
  opacity: 0.8;
}

/* ==================== 底部协议 ==================== */
.login-footer {
  padding: 32rpx;
  text-align: center;
}

.agreement-text {
  font-size: 22rpx;
  color: rgba(232, 243, 255, 0.4);
  line-height: 1.6;
}

/* ==================== 加载遮罩 ==================== */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 14, 26, 0.95);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  text-align: center;
  padding: 48rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  backdrop-filter: blur(20rpx);
}

.loading-spinner {
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid rgba(22, 93, 255, 0.1);
  border-top: 4rpx solid #165DFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 26rpx;
  color: rgba(232, 243, 255, 0.8);
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

/* ==================== 动画 ==================== */
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes breathe {
  0%, 100% {
    opacity: 0.2;
    transform: scale(1);
  }
  50% {
    opacity: 0.4;
    transform: scale(1.1);
  }
}

.fade-in {
  animation: fadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ==================== 响应式调整 ==================== */
@media (max-width: 375px) {
  .login-header {
    height: 400rpx;
  }
  
  .header-content {
    padding: 80rpx 24rpx 48rpx;
  }
  
  .ai-logo {
    width: 100rpx;
    height: 100rpx;
  }
  
  .logo-icon {
    font-size: 48rpx;
  }
  
  .app-name {
    font-size: 44rpx;
  }
  
  .app-slogan {
    font-size: 24rpx;
  }
  
  .login-form {
    padding: 40rpx 24rpx 24rpx;
  }
  
  .login-btn {
    height: 88rpx;
    display: flex; align-items: center; justify-content: center;
    font-size: 28rpx;
  }
}