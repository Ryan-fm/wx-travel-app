/* pages/my-routes/my-routes.wxss */
.container {
  padding-bottom: 120rpx;
}

/* 筛选栏 */
.filter-bar {
  margin-bottom: 24rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: white;
}

.search-section {
  margin-bottom: 24rpx;
}

.search-box {
  position: relative;
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 80rpx 0 32rpx;
  background-color: #f8f8f8;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #333;
}

.search-icon {
  position: absolute;
  left: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #999;
}

.search-clear {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.filter-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.filter-tabs {
  display: flex;
  gap: 20rpx;
}

.filter-tab {
  padding: 12rpx 24rpx;
  background-color: #f8f8f8;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s ease;
}

.filter-tab.active {
  background-color: #4CAF50;
  color: white;
}

.filter-tab:active {
  background-color: #e8f5e9;
}

.action-buttons {
  display: flex;
  gap: 12rpx;
}

.btn-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #f8f8f8;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.btn-icon::after {
  border: none;
}

.btn-icon:active {
  background-color: #e8f5e9;
}

.btn-icon-small {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #f8f8f8;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.btn-icon-small::after {
  border: none;
}

.btn-icon-small:active {
  background-color: #e8f5e9;
}

.btn-icon-small.btn-danger:active {
  background-color: #ffebee;
}

.btn-icon-text {
  font-size: 28rpx;
}

.sort-info {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.sort-text {
  font-size: 24rpx;
  color: #999;
}

/* 路线卡片 */
.routes-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.route-card {
  transition: all 0.3s ease;
}

.route-card:active {
  transform: scale(0.99);
  background-color: #f8f8f8;
}

.route-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.route-title-section {
  flex: 1;
}

.route-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.route-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.route-actions {
  display: flex;
  gap: 8rpx;
}

.route-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
}

.meta-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  color: #666;
}

.meta-text {
  font-size: 24rpx;
  color: #666;
}

.route-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.route-progress {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.progress-bar {
  height: 8rpx;
  background-color: #f0f0f0;
  border-radius: 4rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #4CAF50;
  border-radius: 4rpx;
  animation: progress 2s ease-in-out infinite;
}

@keyframes progress {
  0% { width: 0%; }
  50% { width: 60%; }
  100% { width: 0%; }
}

.progress-text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  display: block;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  color: #ccc;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 48rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx 0;
}

.load-more-text {
  font-size: 28rpx;
  color: #4CAF50;
  padding: 20rpx 40rpx;
  background-color: #f8f8f8;
  border-radius: 40rpx;
  display: inline-block;
}

.load-more-text:active {
  background-color: #e8f5e9;
}

.loading-small {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.loading-spinner-small {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text-small {
  font-size: 26rpx;
  color: #666;
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 40rpx 0;
}

.no-more-text {
  font-size: 26rpx;
  color: #999;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid #f3f3f3;
  border-top: 8rpx solid #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 32rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: white;
  padding: 20rpx;
  border-top: 2rpx solid #f0f0f0;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.bottom-actions button {
  display: flex;
  align-items: center;
  justify-content: center;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 响应式调整 */
@media (max-width: 375px) {
  .route-title {
    font-size: 28rpx;
  }
  
  .filter-tab {
    padding: 10rpx 20rpx;
    font-size: 24rpx;
  }
  
  .meta-text {
    font-size: 22rpx;
  }
  
  .empty-text {
    font-size: 28rpx;
  }
  
  .empty-hint {
    font-size: 24rpx;
  }
}