/* pages/profile/profile.wxss */
.container {
  padding-bottom: 40rpx;
}

/* 用户信息 */
.user-section {
  margin-bottom: 24rpx;
}

.user-header {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.user-avatar.placeholder {
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #999;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 20rpx;
}

.user-stats {
  display: flex;
  gap: 40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

/* 常用目的地 */
.favorites-section {
  margin-bottom: 24rpx;
}

.favorites-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.favorite-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #f8f8f8;
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.favorite-item:active {
  background-color: #e8f5e9;
  transform: scale(0.98);
}

.favorite-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
  color: #4CAF50;
}

.favorite-name {
  font-size: 26rpx;
  color: #333;
}

/* 快速操作 */
.quick-actions {
  margin-bottom: 24rpx;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-top: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.action-item:active {
  background-color: #e8f5e9;
  transform: scale(0.98);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.action-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 菜单列表 */
.menu-section {
  margin-bottom: 24rpx;
}

.menu-list {
  margin-top: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.menu-item:active {
  background-color: #f8f8f8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
  width: 40rpx;
  text-align: center;
}

.menu-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #999;
}

/* 退出登录 */
.logout-section {
  margin: 40rpx 20rpx;
}

.btn-logout {
  width: 100%;
  height: 88rpx;
  background-color: #fff;
  border: 2rpx solid #f0f0f0;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.btn-logout::after {
  border: none;
}

.btn-logout:active {
  background-color: #f8f8f8;
  transform: scale(0.98);
}

.logout-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.logout-text {
  font-size: 30rpx;
  color: #666;
}

/* 版本信息 */
.version-info {
  text-align: center;
  margin-top: 60rpx;
  padding: 0 20rpx;
}

.version-text {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.copyright {
  font-size: 20rpx;
  color: #ccc;
  display: block;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .user-avatar {
    width: 100rpx;
    height: 100rpx;
    margin-right: 24rpx;
  }
  
  .user-name {
    font-size: 32rpx;
  }
  
  .user-id {
    font-size: 22rpx;
  }
  
  .stat-value {
    font-size: 28rpx;
  }
  
  .stat-label {
    font-size: 22rpx;
  }
  
  .favorite-item {
    padding: 12rpx 20rpx;
  }
  
  .favorite-name {
    font-size: 24rpx;
  }
  
  .action-item {
    padding: 24rpx 20rpx;
  }
  
  .action-icon {
    font-size: 40rpx;
  }
  
  .action-text {
    font-size: 24rpx;
  }
  
  .menu-item {
    padding: 24rpx 0;
  }
  
  .menu-text {
    font-size: 28rpx;
  }
  
  .btn-logout {
    height: 80rpx;
  }
  
  .logout-text {
    font-size: 28rpx;
  }
}