<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-section card">
    <view class="user-header" wx:if="{{hasUserInfo}}">
      <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickName}}</text>
        <text class="user-id">ID: {{userInfo.nickName}}@travel.ai</text>
        <view class="user-stats">
          <view class="stat-item">
            <text class="stat-value">{{stats.totalRoutes}}</text>
            <text class="stat-label">路线</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{stats.completedRoutes}}</text>
            <text class="stat-label">已完成</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">¥{{formatMoney(stats.totalBudget)}}</text>
            <text class="stat-label">总预算</text>
          </view>
        </view>
      </view>
    </view>
    
    <view class="user-header" wx:else>
      <view class="user-avatar placeholder">👤</view>
      <view class="user-info">
        <text class="user-name">未登录</text>
        <text class="user-id">请登录后查看个人信息</text>
        <button class="btn-primary mt-20" bindtap="getUserProfile" open-type="getUserProfile">
          立即登录
        </button>
      </view>
    </view>
  </view>

  <!-- 常用目的地 -->
  <view class="favorites-section card" wx:if="{{hasUserInfo && stats.favoriteDestinations.length > 0}}">
    <view class="card-title">常用目的地</view>
    <view class="favorites-list">
      <view class="favorite-item" wx:for="{{stats.favoriteDestinations}}" wx:key="index">
        <text class="favorite-icon">📍</text>
        <text class="favorite-name">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 快速操作 -->
  <view class="quick-actions card" wx:if="{{hasUserInfo}}">
    <view class="card-title">快速操作</view>
    <view class="actions-grid">
      <view class="action-item" bindtap="navigateToGenerate">
        <view class="action-icon">➕</view>
        <text class="action-text">规划路线</text>
      </view>
      <view class="action-item" bindtap="navigateToMyRoutes">
        <view class="action-icon">📋</view>
        <text class="action-text">我的路线</text>
      </view>
      <view class="action-item" bindtap="onCheckUpdate">
        <view class="action-icon">🔄</view>
        <text class="action-text">检查更新</text>
      </view>
      <view class="action-item" bindtap="onClearCache">
        <view class="action-icon">🧹</view>
        <text class="action-text">清除缓存</text>
      </view>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-section">
    <view class="card">
      <view class="card-title">设置与帮助</view>
      <view class="menu-list">
        <view 
          class="menu-item" 
          wx:for="{{menuItems}}" 
          wx:key="id"
          bindtap="onMenuItemTap"
          data-id="{{item.id}}"
        >
          <view class="menu-icon" style="color: {{item.color}}">{{item.icon}}</view>
          <view class="menu-content">
            <text class="menu-text">{{item.name}}</text>
            <text class="menu-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{hasUserInfo}}">
    <button class="btn-logout" bindtap="onLogout">
      <text class="logout-icon">🚪</text>
      <text class="logout-text">退出登录</text>
    </button>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text class="version-text">AI旅游路线规划 v{{version}}</text>
    <text class="copyright">© 2024 Travel AI. All rights reserved.</text>
  </view>
</view>