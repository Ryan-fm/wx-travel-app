/* pages/route-detail/route-detail.wxss - 暗黑系 暖琥珀 */

/* ==================== 容器 ==================== */
.container {
  padding: 0;
  min-height: 100vh;
  background: linear-gradient(135deg, #0d0d0d 0%, #1a1a1a 100%);
}

/* ==================== 加载 ==================== */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid rgba(212, 168, 83, 0.2);
  border-top: 4rpx solid #D4A853;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 28rpx;
}

.loading-spinner.small {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 0;
  margin-right: 16rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #888;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* ==================== 错误 ==================== */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
  text-align: center;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 28rpx;
  color: #aaa;
  margin-bottom: 32rpx;
  line-height: 1.6;
}

/* ==================== 路线详情 ==================== */
.route-detail {
  padding: 0 32rpx calc(140rpx + env(safe-area-inset-bottom));
}

/* ==================== 卡片 ==================== */
.card {
  background: rgba(255, 255, 255, 0.04);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e5e5e5;
  margin-bottom: 24rpx;
}

/* ==================== 头部 ==================== */
.route-header {
  margin: 32rpx 0;
}

.route-title-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.route-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e5e5e5;
  flex: 1;
  margin-right: 16rpx;
}

.route-status {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.route-status.completed {
  background: rgba(82, 196, 26, 0.15);
  color: #52C41A;
}

.route-status.generating {
  background: rgba(212, 168, 83, 0.15);
  color: #D4A853;
}

.route-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #aaa;
}

.meta-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.route-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.route-header .tag {
  padding: 8rpx 16rpx;
  background: rgba(212, 168, 83, 0.15);
  color: #D4A853;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* ==================== 流式输出 ==================== */
.streaming-section {
  margin: 0 0 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.streaming-section .card-title {
  width: 100%;
  text-align: center;
  color: #D4A853;
}

.streaming-output {
  width: 100%;
  padding: 24rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 12rpx;
  box-sizing: border-box;
}

.streaming-text {
  display: block;
  word-break: break-all;
  font-size: 28rpx;
  color: #e5e5e5;
  line-height: 1.6;
  text-align: left;
}

.streaming-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  color: #888;
  font-size: 24rpx;
  gap: 24rpx;
}

.streaming-loading .loading-spinner {
  margin: 0;
}

/* ==================== 图片 ==================== */
.route-image-section {
  margin: 0 0 32rpx;
  overflow: hidden;
}

.route-image {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  background: rgba(0, 0, 0, 0.3);
}

.image-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 8rpx;
}

.hint-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #888;
}

/* ==================== 操作按钮 ==================== */
.action-buttons {
  margin: 0 0 32rpx;
  padding: 24rpx 0;
  display: flex;
  gap: 20rpx;
}

.action-buttons button {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

/* ==================== 地图 ==================== */
.map-section {
  margin: 0 0 32rpx;
}

.map-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 8rpx;
  margin-top: 12rpx;
}

/* map fullscreen modal */
.map-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.9);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.map-modal-content {
  width: 100%;
  height: 100%;
  position: relative;
}

.map-modal-close {
  position: absolute;
  bottom: calc(60rpx + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  padding: 20rpx 48rpx;
  background: rgba(212, 168, 83, 0.9);
  color: #1a1a1a;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* ==================== 行程 ==================== */
.itinerary-section {
  margin: 0 0 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e5e5e5;
}

.section-subtitle {
  font-size: 24rpx;
  color: #888;
}

.days-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.day-card {
  background: rgba(255, 255, 255, 0.04);
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.day-card.expanded {
  box-shadow: 0 4rpx 20rpx rgba(212, 168, 83, 0.15);
}

.day-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.day-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e5e5e5;
  display: block;
  margin-bottom: 6rpx;
}

.day-cost {
  font-size: 24rpx;
  color: #D4A853;
  font-weight: 500;
}

.day-toggle {
  font-size: 24rpx;
  color: #888;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 8rpx;
}

.day-content {
  padding: 0 24rpx 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.activity-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
  gap: 20rpx;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-main {
  flex: 1;
  min-width: 0;
}

.activity-main:active {
  background: rgba(212, 168, 83, 0.08);
  border-radius: 12rpx;
  margin: -12rpx;
  padding: 12rpx;
}

.activity-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.activity-time {
  min-width: 120rpx;
  padding-right: 16rpx;
}

.time-text {
  font-size: 24rpx;
  color: #888;
  font-weight: 500;
}

.activity-details {
  flex: 1;
}

.activity-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.activity-location {
  font-size: 28rpx;
  font-weight: 600;
  color: #e5e5e5;
}

.activity-cost {
  font-size: 24rpx;
  color: #D4A853;
  font-weight: 500;
}

.activity-name {
  font-size: 28rpx;
  color: #ccc;
  display: block;
  margin-bottom: 6rpx;
}

.activity-desc {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.activity-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.action-text {
  font-size: 24rpx;
  color: #D4A853;
  margin-right: 8rpx;
}

.action-icon {
  font-size: 24rpx;
}

/* ==================== 建议 ==================== */
.tips-section,
.transportation-section,
.budget-summary {
  margin: 0 0 32rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
}

.tip-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-top: 2rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #ccc;
  line-height: 1.5;
  flex: 1;
}

.transportation-content {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
}

.transportation-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-top: 2rpx;
}

.transportation-text {
  font-size: 28rpx;
  color: #ccc;
  line-height: 1.5;
  flex: 1;
}

.budget-items {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.budget-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
}

.budget-item.budget-total {
  background: rgba(212, 168, 83, 0.12);
}

.budget-label {
  font-size: 28rpx;
  color: #aaa;
}

.budget-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #e5e5e5;
}

.budget-total .budget-value {
  color: #D4A853;
}

/* ==================== 底部操作 ==================== */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #1a1a1a;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  z-index: 100;
  display: flex;
  gap: 20rpx;
}

.bottom-actions button {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ==================== 调整弹窗 ==================== */
.adjust-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.adjust-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #1a1a1a;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  z-index: 201;
  animation: sheetSlideUp 0.3s ease forwards;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

@keyframes sheetSlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.adjust-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.adjust-sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e5e5e5;
}

.adjust-sheet-close {
  font-size: 28rpx;
  color: #888;
}

.adjust-sheet-body {
  padding: 32rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.adjust-row {
  margin-bottom: 32rpx;
}

.adjust-row:last-child {
  margin-bottom: 0;
}

.adjust-label {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 16rpx;
}

.adjust-input {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border: none;
  border-bottom: 2rpx solid transparent;
  border-radius: 0;
  color: #e5e5e5;
  font-size: 28rpx;
}

.adjust-input:focus {
  border-bottom-color: #D4A853;
}

.adjust-days {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.adjust-day {
  padding: 16rpx 28rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #aaa;
}

.adjust-day.active {
  background: rgba(212, 168, 83, 0.2);
  color: #D4A853;
}

.adjust-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.adjust-tag {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #aaa;
}

.adjust-tag.active {
  background: rgba(212, 168, 83, 0.2);
  color: #D4A853;
}

.adjust-sheet-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.adjust-sheet-footer button {
  flex: 1;
  height: 88rpx;
}

/* ==================== 分享遮罩 ==================== */
.sharing-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(13, 13, 13, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.sharing-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sharing-spinner {
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid rgba(212, 168, 83, 0.2);
  border-top: 4rpx solid #D4A853;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 28rpx;
}

.sharing-text {
  font-size: 28rpx;
  color: #aaa;
  font-weight: 500;
}

/* ==================== 响应式 ==================== */
@media (max-width: 375px) {
  .route-detail {
    padding-left: 24rpx;
    padding-right: 24rpx;
  }

  .route-title {
    font-size: 28rpx;
  }

  .section-title {
    font-size: 28rpx;
  }
}
