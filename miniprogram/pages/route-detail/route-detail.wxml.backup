<!--pages/route-detail/route-detail.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view class="loading" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-state" wx:if="{{isError && !isLoading}}">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{errorMessage}}</text>
    <button class="btn-primary mt-40" bindtap="onRetry">重试</button>
  </view>

  <!-- 路线详情 -->
  <view class="route-detail" wx:if="{{!isLoading && !isError && route}}">
    <!-- 头部信息 -->
    <view class="route-header card">
      <view class="route-title-section">
        <text class="route-title">{{route.title}}</text>
        <text class="route-status {{route.status === 'completed' ? 'completed' : 'generating'}}">
          {{route.status === 'completed' ? '已完成' : '生成中'}}
        </text>
      </view>

      <!-- AI生成的路线图片 -->
      <view class="route-image-section card" wx:if="{{route.imageUrl}}">
        <view class="card-title">AI生成路线图</view>
        <image 
          src="{{route.imageUrl}}" 
          mode="aspectFill" 
          class="route-image"
          bindtap="previewImage"
          data-image="{{route.imageUrl}}"
        />
        <view class="image-hint">
          <text class="hint-icon">🖼️</text>
          <text class="hint-text">点击图片可放大查看</text>
        </view>
      </view>

      <!-- AI生成的路线图片 -->
      <view class="route-image-section card" wx:if="{{route.imageUrl}}">
        <view class="card-title">AI生成路线图</view>
        <image 
          src="{{route.imageUrl}}" 
          mode="aspectFill" 
          class="route-image"
          bindtap="previewImage"
          data-image="{{route.imageUrl}}"
        />
        <view class="image-hint">
          <text class="hint-icon">🖼️</text>
          <text class="hint-text">点击图片可放大查看</text>
        </view>
      </view>

      <!-- AI生成的路线图片 -->
      <view class="route-image-section card" wx:if="{{route.imageUrl}}">
        <view class="card-title">AI生成路线图</view>
        <image 
          src="{{route.imageUrl}}" 
          mode="aspectFill" 
          class="route-image"
          bindtap="previewImage"
          data-image="{{route.imageUrl}}"
        />
        <view class="image-hint">
          <text class="hint-icon">🖼️</text>
          <text class="hint-text">点击图片可放大查看</text>
        </view>
      </view>

      <!-- AI生成的路线图片 -->
      <view class="route-image-section card" wx:if="{{route.imageUrl}}">
        <view class="card-title">AI生成路线图</view>
        <image 
          src="{{route.imageUrl}}" 
          mode="aspectFill" 
          class="route-image"
          bindtap="previewImage"
          data-image="{{route.imageUrl}}"
        />
        <view class="image-hint">
          <text class="hint-icon">🖼️</text>
          <text class="hint-text">点击图片可放大查看</text>
        </view>
      </view>

      <!-- AI生成的路线图片 -->
