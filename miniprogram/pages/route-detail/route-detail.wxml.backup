      <view class="route-image-section card" wx:if="{{route.imageUrl}}">
        <view class="card-title">AI生成路线图</view>
        <image 
          src="{{route.imageUrl}}" 
          mode="aspectFill" 
          class="route-image"
          bindtap="previewImage"
          data-image="{{route.imageUrl}}"
        />
        <view class="image-hint">
          <text class="hint-icon">🖼️</text>
          <text class="hint-text">点击图片可放大查看</text>
        </view>
      </view>
      
      <view class="route-meta">
        <view class="meta-item">
          <text class="meta-icon">📍</text>
          <text class="meta-text">{{route.destination}}</text>
        </view>
        <view class="meta-item">
          <text class="meta-icon">📅</text>
          <text class="meta-text">{{route.days}}天</text>
        </view>
        <view class="meta-item">
          <text class="meta-icon">💰</text>
          <text class="meta-text">¥{{route.budget}}</text>
        </view>
        <view class="meta-item">
          <text class="meta-icon">🕒</text>
          <text class="meta-text">{{route.createdAt}}</text>
        </view>
      </view>

      <view class="route-tags" wx:if="{{route.tags && route.tags.length > 0}}">
        <text class="tag" wx:for="{{route.tags}}" wx:key="index">{{item}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons card">
      <button class="btn-secondary" bindtap="copyRoute">
        <text class="btn-icon">📋</text>
        复制路线
      </button>
      <button class="btn-secondary" bindtap="saveRoute">
        <text class="btn-icon">⭐</text>
        保存
      </button>
      <button class="btn-primary" bindtap="exportRoute">
        <text class="btn-icon">📤</text>
        导出
      </button>
    </view>

    <!-- 地图预览 -->
    <view class="map-section card" wx:if="{{markers.length > 0}}">
      <view class="card-title">路线地图</view>
      <map 
        id="routeMap"
        longitude="{{longitude}}"
        latitude="{{latitude}}"
        scale="{{scale}}"
        markers="{{markers}}"
        polyline="{{polyline}}"
        show-location
        style="width: 100%; height: 400rpx;"
      ></map>
      <view class="map-hint">
        <text class="hint-icon">📍</text>
        <text class="hint-text">点击地点标记查看详情，长按可导航</text>
      </view>
    </view>

    <!-- 行程安排 -->
    <view class="itinerary-section">
      <view class="section-header">
        <text class="section-title">行程安排</text>
        <text class="section-subtitle">总花费：¥{{calculateTotalCost()}}</text>
      </view>
      
      <view class="days-list">
        <view 
          class="day-card {{expandedDay === index ? 'expanded' : ''}}" 
          wx:for="{{route.itinerary}}" 
          wx:key="day"
          bindtap="toggleDay"
          data-index="{{index}}"
        >
          <view class="day-header">
            <view class="day-info">
              <text class="day-title">{{item.title}}</text>
              <text class="day-cost">¥{{item.totalCost || 0}}</text>
            </view>
            <text class="day-toggle">{{expandedDay === index ? '收起' : '展开'}}</text>
          </view>
          
          <view class="day-content" wx:if="{{expandedDay === index}}">
            <view 
              class="activity-item" 
              wx:for="{{item.items}}" 
              wx:key="index"
              bindtap="navigateToLocation"
              data-location="{{item.location}}"
              data-coordinates="{{item.coordinates}}"
            >
              <view class="activity-time">
                <text class="time-text">{{formatTime(item.time)}}</text>
              </view>
              <view class="activity-details">
                <view class="activity-header">
                  <text class="activity-location">{{item.location}}</text>
                  <text class="activity-cost" wx:if="{{item.estimatedCost > 0}}">¥{{item.estimatedCost}}</text>
                </view>
                <text class="activity-name">{{item.activity}}</text>
                <text class="activity-desc">{{item.description}}</text>
                <view class="activity-actions">
                  <text class="action-text">点击查看位置</text>
                  <text class="action-icon">📍</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 实用建议 -->
    <view class="tips-section card" wx:if="{{route.tips && route.tips.length > 0}}">
      <view class="card-title">实用建议</view>
      <view class="tips-list">
        <view class="tip-item" wx:for="{{route.tips}}" wx:key="index">
          <text class="tip-icon">💡</text>
          <text class="tip-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 交通建议 -->
    <view class="transportation-section card" wx:if="{{route.transportation}}">
      <view class="card-title">交通建议</view>
      <view class="transportation-content">
        <text class="transportation-icon">🚗</text>
        <text class="transportation-text">{{route.transportation}}</text>
      </view>
    </view>

    <!-- 预算总结 -->
    <view class="budget-summary card">
      <view class="card-title">预算总结</view>
      <view class="budget-items">
        <view class="budget-item">
          <text class="budget-label">总预算</text>
          <text class="budget-value">¥{{route.budget}}</text>
        </view>
        <view class="budget-item">
          <text class="budget-label">预计花费</text>
          <text class="budget-value">¥{{calculateTotalCost()}}</text>
        </view>
        <view class="budget-item budget-total">
          <text class="budget-label">剩余预算</text>
          <text class="budget-value">¥{{route.budget - calculateTotalCost()}}</text>
        </view>
      </view>
    </view>

    <!-- 底部操作 -->
    <view class="bottom-actions">
      <button class="btn-primary" bindtap="shareRoute" open-type="share">
        <text class="btn-icon">📤</text>
        分享给好友
      </button>
    </view>
  </view>

  <!-- 分享中遮罩 -->
  <view class="sharing-mask" wx:if="{{isSharing}}">
    <view class="sharing-content">
      <view class="sharing-spinner"></view>
      <text class="sharing-text">生成分享图中...</text>
    </view>
  </view>
</view>